@law_crime
view-if: promise_crime_rate == 0
subtitle: [? if campaignpromises == 0 : You should make promises. ?] [? if campaignpromises == 1 : You are a single issue candidate. You could still do more for Gotham. The people need hope. ?] [? if campaignpromises == 2 : A small package. It won't get you any favours for sure, but it's a start. ?] [? if campaignpromises == 3 or campaignpromises == 4 : The standard amount. You have a plan and big issues you want to tackle. ?]  [? if campaignpromises == 5 : Ambitious. But this is what the city needs. ?]
choose-if: campaignpromises <= 5
on-arrival: {!
    Q.promise_crime_rate = 1;
    Q.order += 1;
    Q.red_moderate_relation += 10;
    Q.conservative_relation += 10;
    Q.reactionary_relation += 5;
    Q.approval_rating += 1;
    Q.campaignpromises += 1;
!}

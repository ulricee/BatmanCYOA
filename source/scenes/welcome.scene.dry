choose-if: campaignpromises <= 5
on-arrival: {!
    Q.promise_taxes_lower = 1;

    Q.approval_rating_bruce -= 4;

    Q.red_moderate_relation_bruce += 5;
    Q.conservative_relation_bruce += 5;
    Q.reactionaries_relation_bruce += 5;

    Q.white_collar_support_bruce -= 1;
    Q.blue_collar_support_bruce -= 1;
    Q.business_support_bruce -= 1;
    Q.unemployed_support_bruce -= 1;
    Q.latino_support_bruce -= 1;
    Q.black_support_bruce -= 1;

    Q.campaignpromises += 1;
!}
go-to: admnistration




title: Election
new-page: true
on-arrival: {!

Q.election_1994_seen = 1;

// set quincy's relationship with parties
// Set his relationships with the parties. Right now I just have his red relations at the inverse of Bruce's, and his blue relations tanked.

Q.reactionary_relation_quincy = 75;
Q.conservative_relation_quincy = 50;
Q.red_moderate_relation_quincy = 40;
Q.blue_moderate_relation_quincy = 10;
Q.liberal_relation_quincy = 10;
Q.progressive_relation_quincy = 5;

Q.reform_relation_quincy = 0;
Q.populist_relation_quincy = 0;
Q.libertarian_relation_quincy = 0;
Q.socialist_relation_quincy = 0;
Q.green_relation_quincy = 0;
Q.nationalist_relation_quincy = 0;


Q.approval_rating_quincy = 30;
Q.quincyorder = 50;

// This code is a bit of a mess, I haven't cleaned it up yet and properly commented it.
// I will move it to election algorithm once I set up an elections event

// We start by defining class support

electionCalculate = function(characterName, characterOrder) {

  var character = characterName
  var characterFreedom = characterOrder*(-1)

  function defineValues() {

  // Defining values via for var clutters a lot, so I will do it all in one function

  // Define c_support
      for (var c of Q.classes) {
          Q[c + '_support_' + character] = 0;
      }

      // DEfine bases

      for (var c of Q.classes) {
        Q[c + '_ideology_support_base_' + character] = 0;
      }
      
      for (var c of Q.classes) {
        Q[c + '_party_support_base_' + character] = 0;
      }

    // Define c_max_upport
    for (var c of Q.classes) {
      Q[c + '_max_support'] = 0;
    }

    // define class_support_final 
    for (var c of Q.classes) {
          Q[c + '_support_final_' + character] = 0;
    }  

    // defines bases

  

  }

  function demographicPartySupport() {

      // Converts party alignment into support based on relationship with a given party.

      for (var c of Q.classes) {
        for (var party of Q.parties) {
          Q[c + '_' + party + '_support_' + character] = (Q[c + '_' + party])*((Q[party + '_relation_' + character])/100);
        }
      }

  }

  function demographicIdeologySupport() {

    // Sets base support from ideology
    // bruhh switch is not working 

    Q['ideology_support_status_' + character] = "Null";
    
    if (characterOrder <= -15) {
        Q['ideology_support_status_' + character] = "Radical Liberty";

        Q['white_collar_ideology_support_base_' + character] -= 5;
        Q['blue_collar_ideology_support_base_' + character] -= 10;
        Q['business_ideology_support_base_' + character] -= 15;
        Q['black_ideology_support_base_' + character] += 15;
        Q['latino_ideology_support_base_' + character] += 5;
        Q['unemployed_ideology_support_base_' + character] += 10;
    } else if (characterOrder <= -10 && characterOrder >= -14) {
        Q['ideology_support_status_' + character] = "Liberty";

        Q['white_collar_ideology_support_base_' + character] -= 0;
        Q['blue_collar_ideology_support_base_' + character] -= 10;
        Q['business_ideology_support_base_' + character] -= 10;
        Q['black_ideology_support_base_' + character] += 10;
        Q['latino_ideology_support_base_' + character] += 0;
        Q['unemployed_ideology_support_base_' + character] += 5;
  } else if (characterOrder <= -5 && characterOrder >= -9) {
        Q['ideology_support_status_' + character] = "Liberty Lean";

        Q['white_collar_ideology_support_base_' + character] += 5;
        Q['blue_collar_ideology_support_base_' + character] -= 5;
        Q['business_ideology_support_base_' + character] -= 5;
        Q['black_ideology_support_base_' + character] += 5;
        Q['latino_ideology_support_base_' + character] -= 5;
        Q['unemployed_ideology_support_base_' + character] += 0;
  } else if (characterOrder >= -4 && characterOrder <= 4) {
        Q['ideology_support_status_' + character] = "Moderate"

        Q['white_collar_ideology_support_base_' + character] += 10;
        Q['blue_collar_ideology_support_base_' + character] -= 0;
        Q['business_ideology_support_base_' + character] -= 0;
        Q['black_ideology_support_base_' + character] += 0;
        Q['latino_ideology_support_base_' + character] -= 10;
        Q['unemployed_ideology_support_base_' + character] += 0;
  } else if (characterOrder >= 5 && characterOrder <= 9) {
        Q['ideology_support_status_' + character] = "Order Lean";
        
        Q['white_collar_ideology_support_base_' + character] += 5;
        Q['blue_collar_ideology_support_base_' + character] += 5;
        Q['business_ideology_support_base_' + character] += 5;
        Q['black_ideology_support_base_' + character] -= 5;
        Q['latino_ideology_support_base_' + character] -= 5;
        Q['unemployed_ideology_support_base_' + character] -= 5;
  } else if (characterOrder >= 10 && characterOrder <= 14) {
        Q['ideology_support_status_' + character] = "Order";

        Q['white_collar_ideology_support_base_' + character] -= 0;
        Q['blue_collar_ideology_support_base_' + character] += 10;
        Q['business_ideology_support_base_' + character] += 10;
        Q['black_ideology_support_base_' + character] -= 10;
        Q['latino_ideology_support_base_' + character] += 0;
        Q['unemployed_ideology_support_base_' + character] -= 10;
  } else if (characterOrder >= 14) {
        Q['ideology_support_status_' + character] = "Radical Order";

        Q['white_collar_ideology_support_base_' + character] -= 5;
        Q['blue_collar_ideology_support_base_' + character] += 10;
        Q['business_ideology_support_base_' + character] += 15  ;
        Q['black_ideology_support_base_' + character] -= 15;
        Q['latino_ideology_support_base_' + character] += 5;
        Q['unemployed_ideology_support_base_' + character] -= 15;
  }

  }

  function demographicSupportBases() {

      for (var c of Q.classes) {
        for (var party of Q.parties) {
          Q[c + '_party_support_base_' + character] += (Q[c + '_' + party + '_support_' + character]);
        }
      }

      for (var c of Q.classes) {
        Q[c + '_support_' + character] += Q[c + '_party_support_base_' + character]
        Q[c + '_support_' + character] += Q[c + '_ideology_support_base_' + character]      
      }

      // TO DO: Add in political honeymoon  

  }

  function demographicIdeology() {


  // First, we determine how impacted a given demographic is by the character's ideology.

    Q['unemployed_ideology_base_' + character] = characterOrder/4;
    Q['blue_collar_ideology_base' + character] = characterOrder/2;
    Q['white_collar_ideology_base' + character] = characterFreedom/2;
    Q['black_ideology_base' + character] = characterFreedom/2;
    Q['latino_ideology_base' + character] = characterFreedom/4;
    Q['business_ideology_base' + character] = characterOrder;

    // remember to add in a cap to black and latino minorities later.

    // Calculate the total pool for distribution in the approval rating.

    Q['ideology_support_' + character] = 0;

      for (var c of Q.classes) {
          if ([Q[c + '_ideology_base_' + character]] == 0) {
            Q[c + '_ideology_base_' + character] = 1;
          }      
          if (Q[c + '_ideology_base_' + character] > 0) {
            Q['ideology_support_' + character] += (Q[c + '_ideology_base_' + character]);
          } else if ([Q[c + '_ideology_base']] < 0) {
            Q['ideology_support_' + character] += (Q[c + '_ideology_base_' + character])*(-1);
          }
    }

    // Now we'll divide the ideology share to find the "pull".

    Q['unemployed_ideology_' + character] = (Q['unemployed_ideology_base_' + character]/Q['ideology_support_' + character]);
    Q['blue_collar_ideology_' + character] = (Q['blue_collar_ideology_base_' + character]/Q['ideology_support_' + character]);
    Q['white_collar_ideology_' + character] = (Q['white_collar_ideology_base_' + character]/Q['ideology_support_' + character]);
    Q['black_ideology_' + character] = (Q['black_ideology_base_' + character]/Q['ideology_support_' + character]);
    Q['latino_ideology_' + character] = (Q['latino_ideology_base_' + character]/Q['ideology_support_' + character]);
    Q['business_ideology_' + character] = (Q['business_ideology_base_' + character]/Q['ideology_support_' + character]);

  // We will now scale current demographic support by the ideology.


  //for (var c of Q.classes) {
  //       Q[c + '_support_' + character] = Q[c + '_support_' + character]*(1+(Q[c + '_ideology_' + character]));
  //  }

  }

  function districtParty() {

    for (var party of Q.parties) {
      for (var c of Q.classes) {
        for (var district of Q.districts) {  
          Q[c + '_' + party + '_' + district + '_change'] = Q[c + '_' + party + '_' + district]-Q[c + '_' + party + '_' + district + '_old']
          Q[c + '_' + party + '_' + district + '_city_change'] = Q[c + '_' + party + '_' + district + '_change']*(Q[district + '_size']/100)
          Q[c + '_' + party] += Q[c + '_' + party + '_' + district + '_city_change'];
        }
      }  
    }
    
    
    
    for (var c of Q.classes) {
          Q[c + '_' + party + '_change'] = Q[c + '_' + party]-Q[c + '_' + party + '_old'];
          for (var district of Q.districts) {
              Q[c + '_' + party + '_' + district + '_change'] = Q[c + '_' + party + '_change']*(Q[c + '_district']/100);
        }
      }  

  // Remember to set old values in post event

  }

  function thedistrictSupport() {

  for (var district of Q.districts) {
    for (var c of Q.classes) {
          Q[c + '_' + district + '_percent_add_' + character] = 0;
          Q[c + '_' + district + '_percent_' + character] = (Q[c + '_support_' + character] + Q[c + '_' + district + '_percent_add_' + character]);
        }  
  }



  // c_district_percent is scaled by the district size to give us c_district_support, which is say, "4.4% in burnley support you out of 8%"

  for (var district of Q.districts) {
    for (var c of Q.classes) {
          Q[c + '_' + district + '_support_' + character] = Q[c + '_' + district + '_percent_' + character]*(Q[c + '_' + district]/100);
        }  
  }

  // c_district_city is the city wide support, simply c_district_percent scaled by the district's size in the overall city.

  for (var district of Q.districts) {
    for (var c of Q.classes) {
          Q[c + '_' + district + '_city_' + character] = Q[c + '_' + district + '_support_' + character]*(Q[district + "_size"]/100);
        }  
  }


  // c_city_total is essentially how many people are there in a specific district. (e.c the latter part of "4% out of 8%"")

  for (var district of Q.districts) {
    for (var c of Q.classes) {
          Q[c + '_' + district + '_city_total'] = Q[c + '_' + district]*(Q[district + "_size"]/100);
        }  
  }

  // c_max_support is the maximum support you can get out of a demographic across the entire city. Basically the district city totals added together.


  for (var district of Q.districts) {
    for (var c of Q.classes) {
          Q[c + '_max_support'] += Q[c + '_' + district + '_city_total']
        }  
  }

  // c_support_final is the combination of all your support with a given demographic across the city

  for (var c of Q.classes) {
    for (var district of Q.districts) {
          Q[c + '_support_final_' + character] += Q[c + '_' + district + '_city_' + character]
        }  
  }

// Sum up all of them to get the citywide support.

  Q['city_support_' + character] = 0;

  for (var district of Q.districts) {
    for (var c of Q.classes) {
          Q['city_support_' + character] += Q[c + '_' + district + '_city_' + character];
        }  
  }

  // district_total is the sum of all the c_district_support together. This is basically the district support in %


  for (var district of Q.districts) {
    Q[district + '_total_' + character] = 0;
    for (var c of Q.classes) {
          Q[district + '_total_' + character] += Q[c + '_' + district + '_support_' + character];
        }  
  }

  // c_district_total is the "chunk" of district_total for a given class (basically how much each class contributed to district_total)

  for (var district of Q.districts) {
    for (var c of Q.classes) {
          Q[c + '_' + district + '_total_' + character] = (Q[c + '_' + district + '_support_' + character]/Q[district + '_total'])*100;
        }  
  }

  }
  
// Must add seats later on.

  function districtCity() {
    // Here, we first calculate numbers based on city population. This is mostly for fluff as what really matters in this game is the % of how many people support you.
    // We have changes on the city wide sum of district support from last turn to this turn. This is the c_district_change. The c_real_support is also increased by it.

      
    for (var c of Q.classes) {
      Q[c + '_districts_' + character] = 0;
      for (var district of Q.districts) {
            Q[c + '_districts_' + character] += Q[c + '_' + district + '_city_' + character];
          }  
    }

    for (var c of Q.classes) {
      Q[c + '_districts_change_' + character] = 0;
      for (var district of Q.districts) {
            Q[c + '_' + district + '_city_' + character + '_old'] = Q[c + '_' + district + '_city_' + character]
            Q[c + '_districts_change_' + character] = Q[c + '_' + district + '_city_' + character]-Q[c + '_' + district + '_city_' + character + '_old'];
          }  
    }




  // Remember do add in c_real_support here

  }

  function approvalRating() {

    // We have an approval change, which is the increase between last turn's and this turn's "real approval" 
    // (e.c not the approval rating, but the current sum of all classes as a result of last changes). 
    // This is added to the approval rating, so if a player does something to increase their popularity with a specific demographic,
    //  this is reflected on the approval.
  
    Q['approval_change_' + character] = 0;

    for (var c of Q.classes) {
        Q[c + '_support_old_' + character] = Q[c + '_support_' + character]
    }

    for (var c of Q.classes) {
      Q[c + '_approval_change_' + character] = Q[c + '_support_' + character]-Q[c + '_support_old_' + character];
      Q['approval_change_' + character] += Q[c + '_approval_change_' + character];
    }

    Q['approval_rating_' + character] += Q['approval_change_' + character];

    //We have an approval gap, which is the difference between the approval rating and each c_support. 
    // They are all added up, and the difference is split across based on ideological weight, 
    // making sure that the current c_support equals the approval rating. 
    // This is specifically if you lose global approval, or if you win global approval, it affects the classes or etcetera.

    Q['approval_gap_' + character] = 0;

    for (var c of Q.classes) {
      Q[c + '_approval_gap_' + character] = Q['approval_rating_' + character]-Q[c + '_support_' + character];
      Q['approval_gap_' + character] += Q[c + '_approval_gap_' + character];
    }

    for (var c of Q.classes) {
      Q[c + '_support_' + character] += Q['approval_gap_' + character]/6;
  
    }
    
    // TO DO: Add in ideological weight.

  }

  function parseElectionFloats () {
    // This is used to turn stuff into 2 digits decimals
    for (var c of Q.classes) {
      Q[c + '_support_' + character] = parseFloat((Q[c + '_support_' + character]).toFixed(2))
    }
    // Districts
    for (var c of Q.classes) {
      for (var district of Q.districts) {
        Q[c + '_' + district + '_percent_' + character] = parseFloat((Q[c + '_' + district + '_percent_' + character]).toFixed(2))
        Q[c + '_' + district + '_support_' + character] = parseFloat((Q[c + '_' + district + '_support_' + character]).toFixed(2))
        Q[c + '_' + district + '_city_' + character] = parseFloat((Q[c + '_' + district + '_city_' + character]).toFixed(2))
        Q[c + '_' + district + '_city_total'] = parseFloat((Q[c + '_' + district + '_city_total']).toFixed(2))
        Q[c + '_max_support'] = parseFloat((Q[c + '_max_support']).toFixed(2))
        Q[c + '_' + district + '_total_' + character] = parseFloat((Q[c + '_' + district + '_total_' + character]).toFixed(2))
        Q[district + '_total_' + character] = parseFloat((Q[district + '_total_' + character]).toFixed(2))
        Q[c + '_support_final_' + character] = parseFloat((Q[c + '_support_final_' + character]).toFixed(2))
      }
    }

    Q['city_support_' + character] = parseFloat((Q['city_support_' + character]).toFixed(2))

  }

// TO DO: Add in real_c_support



  // Updated approval changes the district: 

// Updates related values to c_party_district (percent and city): 


defineValues();

demographicPartySupport();

demographicIdeologySupport();

demographicSupportBases();

demographicIdeology();

districtParty();

thedistrictSupport(); 

districtCity();

approvalRating();

parseElectionFloats();

}

electionCalculate('bruce', Q.order);

electionCalculate('quincy', Q.quincyorder);

Q.swing_voters_1994 = Q.city_support_bruce - Q.city_support_quincy

Q.bruce_swing_1994 = 0.9*(Q.swing_voters_1994)

Q.quincy_swing_1994 = 0.1*(Q.swing_voters_1994)

Q.total_votes = ((Q.city_support_bruce + Q.bruce_swing_1994)+(Q.city_support_quincy + Q.quincy_swing_1994))

Q.bruce_final_1994 = parseFloat((((Q.city_support_bruce + Q.bruce_swing_1994)/Q.total_votes)*100).toFixed(2))

Q.quincy_final_1994 = parseFloat((((Q.city_support_quincy + Q.quincy_swing_1994)/Q.total_votes)*100).toFixed(2))


!}

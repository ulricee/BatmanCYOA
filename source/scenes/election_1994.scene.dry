// approval gap districts


    Q['district_approval_gap_' + character] = 0;

    for (var district of Q.districts) {
      Q['district_approval_gap_' + character] += (Q[district + '_total_' + character])*(Q[district + '_size']/100);
    }

    Q['district_approval_gap_final_' + character] = Q['district_approval_gap_' + character] - Q['approval_rating_' + character];


  for (var district of Q.districts) {
      Q['district_approval_gap_final_' + character + '_old'] = Q['district_approval_gap_final_' + character];

@victory
on-arrival: {!

  
  for (var c of Q.classes) {
      Q[c +'_support_old_bruce'] = Q[c + '_support_bruce'];
  }



if (Q.approval_rating_bruce > Q.approval_rating_bruce_old)   {
    Q.approval_rating_bruce_up = 2;
} else if (Q.approval_rating_bruce_old == Q.approval_rating_bruce) {
    Q.approval_rating_bruce_up = 1;
} else { 
    Q.approval_rating_bruce_up = 0;
}

if (Q.credibility > Q.credibility_old) {
    Q.credibility_up = 2;
} else if (Q.credibility_old == Q.credibility) {
    Q.credibility_up = 1;
} else { 
    Q.credibility_up = 0;
}

if (Q.pf > Q.pf_old) {
    Q.pf_up = 2;
} else if (Q.pf_old == Q.pf) {
    Q.pf_up = 1;
} else { 
    Q.pf_up = 0;
}

if (Q.budget > Q.budget_old) {
    Q.budget_up = 2;
} else if (Q.budget_old == Q.budget) {
    Q.budget_up = 1;
} else { 
    Q.budget_up = 0;
}


if (Q.poverty > Q.poverty_old) {
    Q.poverty_up = 2;
} else if (Q.poverty_old == Q.poverty) {
    Q.poverty_up = 1;
} else { 
    Q.poverty_up = 0;
}


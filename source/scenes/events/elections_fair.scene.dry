 displayProgressiveSeat = function () {
    const resultsDiv = document.getElementById('hiddenprogressive2');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};


 displayRepublicanSeats = function () {
    displayRepSeat();
    displayConservativeSeat();
    displayReactionarySeat();
}

 displayDemocratSeats = function () {
    displayProgressiveSeat();
    displayLiberalSeat();
    displayDemSeat();
};
    var r = document.getElementsByClassName('seat reactionary');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayReactionarySeat);
}

    var r = document.getElementsByClassName('seat conservative');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayConservativeSeat);
}

    var r = document.getElementsByClassName('seat red_moderate');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayRepSeat);
}

    var r = document.getElementsByClassName('seat blue_moderate');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayDemSeat);
}

    var r = document.getElementsByClassName('seat liberal');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayLiberalSeat);
}

    var r = document.getElementsByClassName('seat progressive');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayProgressiveSeat);
}


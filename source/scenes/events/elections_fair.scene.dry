title: Elections
new-page: true
tags: event
view-if: year = 1995 and month = 2
max-visits: 1
on-display: {!
data = [
    {
        "id": "reactionary",
        "legend": "Reactionary",
        "name": "Reactionary",
        "seats": Math.round(Q.reactionary_s),
    },
    {
        "id": "conservative",
        "legend": "Conservative",
        "name": "Conservative",
        "seats": Math.round(Q.conservative_s),
    },
    {
        "id": "red_moderate",
        "legend": "Republican Moderate",
        "name": "Republican Moderate",
        "seats": Math.round(Q.red_moderate_s),
    },
    {
        "id": "blue_moderate",
        "legend": "Moderate Democrat",
        "name": "Moderate Democrat",
        "seats": Math.round(Q.blue_moderate_s),
    },
    {
        "id": "liberal",
        "legend": "Liberal",
        "name": "Liberal",
        "seats": Math.round(Q.liberal_s),
    },
    {
        "id": "progressive",
        "legend": "Progressive",
        "name": "Progressive",
        "seats": Math.round(Q.progressive_s),
    },
];



if (window && d3) {
    var width = 1000; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("parliament").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#parliament").datum(data).call(parliament);
}

 displayReactionarySeat = function () {
    const resultsDiv = document.getElementById('hiddenreaction2');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};

 displayConservativeSeat = function () {
    const resultsDiv = document.getElementById('hiddenconservative2');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};

 displayRepSeat = function () {

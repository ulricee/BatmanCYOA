title: Status
new-page: true
is-special: true
on-display: {!
data = [
    {
        "id": "reactionary",
        "legend": "Reactionary",
        "name": "Reactionary",
        "seats": Math.round(Q.reactionary_s),
    },
    {
        "id": "conservative",
        "legend": "Conservative",
        "name": "Conservative",
        "seats": Math.round(Q.conservative_s),
    },
    {
        "id": "red_moderate",
        "legend": "Republican Moderate",
        "name": "Republican Moderate",
        "seats": Math.round(Q.red_moderate_s),
    },
    {
        "id": "blue_moderate",
        "legend": "Moderate Democrat",
        "name": "Moderate Democrat",
        "seats": Math.round(Q.blue_moderate_s),
    },
    {
        "id": "liberal",
        "legend": "Liberal",
        "name": "Liberal",
        "seats": Math.round(Q.liberal_s),
    },
    {
        "id": "progressive",
        "legend": "Progressive",
        "name": "Progressive",
        "seats": Math.round(Q.progressive_s),
    },
];



if (window && d3) {
    var width = 200; 
    var height = 100;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}


 displayReactionarySeat = function () {
    const resultsDiv = document.getElementById('hiddenreaction');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};

 displayConservativeSeat = function () {
    const resultsDiv = document.getElementById('hiddenconservative');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};

 displayRepSeat = function () {
    const resultsDiv = document.getElementById('hiddenred');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};

 displayDemSeat = function () {
    const resultsDiv = document.getElementById('hiddenblue');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};



 displayLiberalSeat = function () {
    const resultsDiv = document.getElementById('hiddenliberal');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};


 displayProgressiveSeat = function () {
    const resultsDiv = document.getElementById('hiddenprogressive');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};


 displayRepublicanSeats = function () {
    displayRepSeat();
    displayConservativeSeat();
    displayReactionarySeat();
}

 displayDemocratSeats = function () {
    displayProgressiveSeat();
    displayLiberalSeat();
    displayDemSeat();
};
    var r = document.getElementsByClassName('seat reactionary');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayReactionarySeat);
}

    var r = document.getElementsByClassName('seat conservative');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayConservativeSeat);
}

    var r = document.getElementsByClassName('seat red_moderate');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayRepSeat);
}

    var r = document.getElementsByClassName('seat blue_moderate');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayDemSeat);
}

    var r = document.getElementsByClassName('seat liberal');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayLiberalSeat);
}

    var r = document.getElementsByClassName('seat progressive');
for (var i = 0; i < r.length; i++) {
    r[i].style.pointerEvents = 'all';
    r[i].style.cursor = 'pointer';
    r[i].addEventListener('click', displayProgressiveSeat);
}

!}


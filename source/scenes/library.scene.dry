@figures
title: Figures and Charts
on-arrival: {!

    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    }

    var minCrime = d3.min(Q.crime_records, d => d.crime);
    var maxPolice = d3.min(Q.crime_records, d => d.crime);
    var lines_3 = d3.linegraph(true, true, ['crime', 'police'],
            {'crime': '#0000FF', 'police': '#FF0000'},
            {'crime': 'Crime', 'police': 'Police'},
            maxPolice + 5, minCrime - 5, 21);
    lines_3.width(width).height(300);
    d3.select("#crime_history").datum(Q.crime_records).call(lines_3);!}

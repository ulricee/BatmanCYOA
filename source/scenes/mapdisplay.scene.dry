title: map
new-page: true
is-special: true
on-arrival: {!

   Q.onmain = 0

   // if (Q.onmain == 0) {
   //   const elements = document.querySelectorAll('header, #mainwrapper, footer');
   //   elements.forEach(el => {
   //      el.style.maxWidth = '5400px';
   //   });
   // }



 showNewGotham = function () {
    const resultsDiv = document.getElementById('mapNewGothamInfo');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }

   (function() {
    function scrollHorizontally(e) {
        e = window.event || e;
        var delta = Math.max(-1, Math.min(1, (e.wheelDelta || -e.detail)));
        this.scrollLeft -= (delta * 40); // Multiplied by 40
        e.preventDefault();
    }
    if (document.getElementById('maptablenewgotham').addEventListener) {
        // IE9, Chrome, Safari, Opera
        document.getElementById('maptablenewgotham').addEventListener('mousewheel', scrollHorizontally, false);
        // Firefox
        document.getElementById('maptablenewgotham').addEventListener('DOMMouseScroll', scrollHorizontally, false);
    } else {
        // IE 6/7/8
        document.getElementById('maptablenewgotham').attachEvent('onmousewheel', scrollHorizontally);
    }
})();
};


!}
on-display: {!

//     const toolsWrapper = document.getElementById('tools_wrapper');
//  if (toolsWrapper) {
//  toolsWrapper.style.display = 'none';
//  }

   
   let whitecollarnewgotham = Q.white_collar_new_gotham
   let bluecollarnewgotham = Q.blue_collar_new_gotham
   let businessnewgotham = Q.business_new_gotham
   let blacknewgotham = Q.black_new_gotham
   let latinonewgotham = Q.latino_new_gotham
   let unemployednewgotham = Q.unemployed_new_gotham

    var data = [whitecollarnewgotham, bluecollarnewgotham, businessnewgotham, blacknewgotham, latinonewgotham, unemployednewgotham];

    var svg = d3.select("#test"),
        width = svg.attr("width"),
        height = svg.attr("height"),
        radius = Math.min(width, height) / 2,
        g = svg.append("g").attr("transform", "translate(" + width / 2 + "," + height / 2 + ")");

    var color = d3.scaleOrdinal(['#ffffff','#008cff','#ffd000','#603b66','#aee41a', '#af0000']);

    // Generate the pie
    var pie = d3.pie();

    // Generate the arcs
    var arc = d3.arc()
                .innerRadius(0)
                .outerRadius(radius);

    //Generate groups
    var arcs = g.selectAll("arc")
                .data(pie(data))
                .enter()
                .append("g")
                .attr("class", "arc")

    //Draw arc paths
    arcs.append("path")
        .attr("fill", function(d, i) {
            return color(i);
        })
        .attr("d", arc);


   svgPanZoom('#svg1');

!}
on-departure: {!
     const toolsWrapper = document.getElementById('tools_wrapper');
  
  if (toolsWrapper) {
  toolsWrapper.style.display = 'block';
  }

!}


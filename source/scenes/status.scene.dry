 displayMayorBudget = function () {
    const resultsDiv = document.getElementById('hiddenbudget');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
};

    document.getElementById("mayorbudgetshow").addEventListener("click", function(){
        const resultsDiv = document.getElementById('hiddenbudget');
      // Toggle display between 'none' and 'block'
      if (resultsDiv.style.display === 'none' || resultsDiv.style.display === '') {
          resultsDiv.style.display = 'block'; // or 'table' for the table specifically
      } else {
          resultsDiv.style.display = 'none';
      }
    })

nametabchange = function () {
    
        if (Q.seeingasbruce == 1) {
            if (Q.bruce >= Q.batman) {
                var elem = document.getElementById("main_tab");
                elem.innerHTML = "You"
            } 
            if (Q.bruce < Q.batman) {
                var elem = document.getElementById("main_tab");
                elem.innerHTML = "Bruce"
            }

        }
        
        if (Q.seeingasbatman == 1) {
            if (Q.batman >= Q.bruce) {
                var elem = document.getElementById("main_tab");
                elem.innerHTML = "You"
            } 
            if (Q.batman < Q.bruce) {
                var elem = document.getElementById("main_tab");
                elem.innerHTML = "Batman"
            }

        }
}


    enableBatmanModeStatus = function () {
        Q.seeingasbruce = 0;
        Q.seeingasbatman = 1;
        enableBatmanMode();
        document.getElementById('batman_div').style.display = "block";
        document.getElementById('bruce_wayne_div').style.display = "none";
        nametabchange();

    }

    disableBatmanModeStatus = function () {
        Q.seeingasbruce = 1;
        Q.seeingasbatman = 0;
        disableBatmanMode();
        document.getElementById('batman_div').style.display = "none";
        document.getElementById('bruce_wayne_div').style.display = "block";
        nametabchange();

    }


!}


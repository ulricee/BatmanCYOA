@crime
on-display: {!

    var width = 500;
    var height = 500;

    var minCrime = d3.min(Q.crime_records, d => d.crime);
    var maxPolice = d3.min(Q.crime_records, d => d.crime);
    var lines_3 = d3.linegraph(true, true, ['crime', 'police', 'penguin', 'falcone', 'ventriloquist', 'black_mask', 'white_shark', 'snapjaw'],
            {'crime': '#ff0000', 'police': '#001aff', 'penguin': '#40008a', 'falcone': '#ffffff', 'ventriloquist': '#7f9e83', 'white_shark': '#b88686', 'snapjaw': '#0f5c38'},
            {'crime': 'Crime', 'police': 'Police Spending', 'penguin': 'Penguin', 'falcone': 'Falcone', 'ventriloquist': 'The Ventriloquist', 'white_shark': 'White Shark', 'snapjaw': 'Snapjaw Gang'},
            maxPolice + 70, minCrime - 75, 21);
    lines_3.width(width).height(300);
    d3.select("#crime_history2").datum(Q.crime_records).call(lines_3);

(function() {
    function scrollHorizontally(e) {
        e = window.event || e;
        var delta = Math.max(-1, Math.min(1, (e.wheelDelta || -e.detail)));
        this.scrollLeft -= (delta * 40); // Multiplied by 40
        e.preventDefault();
    }
    if (document.getElementById('crime_history_box').addEventListener) {
        // IE9, Chrome, Safari, Opera
        document.getElementById('crime_history_box').addEventListener('mousewheel', scrollHorizontally, false);
        // Firefox
        document.getElementById('crime_history_box').addEventListener('DOMMouseScroll', scrollHorizontally, false);
    } else {
        // IE 6/7/8
        document.getElementById('crime_history_box').attachEvent('onmousewheel', scrollHorizontally);
    }
})();




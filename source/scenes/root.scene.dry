title: Root Scene
new-page: true
go-to: post_event if started = 1; start_menu if started = 0
on-arrival: {!
  Q.toolsonce = 0;
 
  const toolsWrapper = document.getElementById('tools_wrapper');
  
  if (Q.toolsonce == 0) {
  if (toolsWrapper) {
  toolsWrapper.style.display = 'none';
  }
  Q.toolsonce = 1;

  const video = document.getElementById('video-wrapper');
  if (video) {
    video.style.display = 'none';
  }
} 
!}
on-display: {!
      window.enableBatmanMode();
!}


@start_menu
new-page: true
go-to: start_menu_2

= Gotham: A place you never leave.

@start_menu_2
on-arrival: {!
  dendryUI.audioPlaylist = []
!}
audio: audio/vinyl.mp3


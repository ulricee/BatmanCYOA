};

// schizo algorithm to assign a district to each seat

for (var electoral_district of Q.electoral_district) {
  for (var party of Q.parties) {
    Q[electoral_district + '_seats_' + party + '_tobeassigned'] = (Q[electoral_district + '_seats_' + party]);
  }
};



  for (var electoral_district of Q.electoral_district) {
    Q[electoral_district + '_seats_tobeassigned'] = (Q[electoral_district + '_seats']);
  }

for (var seat of Q.seats) {    
    for (var electoral_district of Q.electoral_district) {
      if (Q[electoral_district + '_seats_tobeassigned'] > 0) {
        if (!Q[seat + '_district']) {
          Q[seat + '_district'] = electoral_district;
          Q[electoral_district + '_seats_tobeassigned'] -= 1
        };    
      };
        for (var party of Q.parties) {
          if (!Q[seat + '_district_alignment']) {
            if (Q[electoral_district + '_seats_' + party +  '_tobeassigned'] > 0) {
              Q[seat + '_district_alignment'] = party;
              Q[electoral_district + '_seats_' + party + '_tobeassigned'] -= 1;
            };
          };
        };
      };
    };





// other stuff

Q.council_s = (Q.reactionary_s + Q.conservative_s + Q.red_moderate_s + Q.blue_moderate_s + Q.liberal_s + Q.progressive_s);
Q.democrat_s = (Q.blue_moderate_s + Q.liberal_s + Q.progressive_s);
Q.republican_s = (Q.reactionary_s + Q.conservative_s + Q.red_moderate_s);

for (var party of Q.parties) {
    Q[party + '_percent'] = ((Q[party + '_s']/Q.council_s)*100).toFixed(1); 
};

// array of objects of the form {date: Date(), spd: 10, kpd: 12, ...} for each election
Q.election_records = [];
// party support records for every month
Q.party_support_records = [];
// inflation and unemployment records
Q.economic_records = [];

Q.electoral_threshold = 0;

// Advisors/Leaders
Q.n_advisors = 3;
// timer - this decrements by 1 every turn, and is set to 5 whenever an advisor action is used, so that you can only use one advisor action every 5 months.
// let's just put all of the timers here...
// most party affairs and government affairs cards are on a timer.
Q.timers = ['advisor_action'];
Q.advisor_action_timer = 0;

// initial advisors.
Q.gordon_advisor = 1; // James Gordon
Q.rupert_advisor = 1; // Rupert Thorne
Q.lucius_advisor = 1; // Lucius Fox

// Police Commissioners

Q.harvey_advisor = 0; //Harvey Bullock
Q.gil_advisor = 0; // Gil Mason
Q.montoya_advisor = 0; // Renée Montoya

// Speakers

Q.hamilton_advisor = 0; // Hamilton Hill (Liberal Democrat)
Q.doug_advisor = 0; // Doug Thomas (Independant)

// Business Advisor
Q.selina_advisor = 0; // Selina Kyle
Q.alfred_advisor = 0; // Alfred Pennyworth

// Initial state of charities
Q.charity_burnley = 0;
Q.charity_somerset = 1;
Q.charity_bristol = 0;
Q.charity_new_gotham = 0;
Q.charity_old_gotham = 1;
Q.charity_burnside = 1;

Q.charity_total = 3;

Q.charity_canary = 0;

// contacts
Q.clark = 0;
Q.busy_canary = 1;

dendryUI.audioPlaylist = []

!}
audio: audio/batmanbackground.mp3
set-bg: img/map_2.jpg
new-page: true

- @1928_debug: Debug Enter
- @1928_normal: Begin (normal difficulty)
- @1928_hard: Begin (hard difficulty)
- @1928_historical: Begin (historical mode)

@1928_debug
on-arrival:  {!
  Q.difficulty = -2
!}

@1928_easy
on-arrival: {!
  Q.difficulty = -1
!}
go-to: welcome

@1928_hard
on-arrival: {!
  Q.difficulty = 1
!}
go-to: welcome

@1928_historical
on-arrival: {!
Q.difficulty = 2;
Q.historical_mode = 1;
this.state.disableSaves = true;
!}
go-to: welcome

@1928_normal
on-arrival: {!
  Q.difficulty = 0
!}
go-to: welcome

@1928_main
new-page: true
go-to: main if difficulty >= 0; main.main_easy if difficulty < 0

= January 1994


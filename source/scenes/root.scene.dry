Q.electoral_threshold = 0;

// Advisors/Leaders
Q.n_advisors = 3;
// timer - this decrements by 1 every turn, and is set to 5 whenever an advisor action is used, so that you can only use one advisor action every 5 months.
// let's just put all of the timers here...
// most party affairs and government affairs cards are on a timer.
Q.timers = ['advisor_action', 'business_board_reform_implementing'];
Q.advisor_action_timer = 0;
Q.business_board_reform_implementing_timer = 0;

// initial advisors.
Q.gordon_advisor = 1; // James Gordon
Q.rupert_advisor = 1; // Rupert Thorne
Q.lucius_advisor = 1; // Lucius Fox

// Police Commissioners

Q.harvey_advisor = 0; //Harvey Bullock
Q.gil_advisor = 0; // Gil Mason
Q.montoya_advisor = 0; // Renée Montoya

// Speakers

Q.hamilton_advisor = 0; // Hamilton Hill (Liberal Democrat)
Q.doug_advisor = 0; // Doug Thomas (Independant)

// Business Advisor
Q.selina_advisor = 0; // Selina Kyle
Q.alfred_advisor = 0; // Alfred Pennyworth

// Initial state of charities
Q.charity_burnley = 0;
Q.charity_somerset = 1;
Q.charity_bristol = 0;
Q.charity_new_gotham = 0;
Q.charity_old_gotham = 1;
Q.charity_burnside = 1;

Q.charity_total = 3;

Q.charity_canary = 0;

// contacts
Q.clark = 0;
Q.busy_canary = 1;
Q.ferris_boyle_active = 1;
Q.harvey_helping_city_reform = 0;

// Personal Relationships
Q.talia_relationship = 50;
Q.cassandra_relationship = 50;
Q.shiva_relationship = 50;
Q.andrea_relationship = 50;
Q.selina_relationship = 30;
Q.ra_relationship = 50;
Q.roman_sionis_relationship = 50;
Q.harvey_relation = 50;
Q.harvey_sanity = 50;
Q.dick_relation = 50;

// Advisor relationships
Q.gordon_relation = 50;
Q.rupert_thorne_relation = 30;
Q.hamilton_relation = 50;
Q.doug_relation = 50;

// Flags
Q.ra_successor = "Ra"
Q.daoist = 0;
Q.confucius = 0;
Q.legalist = 0;
Q.mohism = 0;
Q.freethinker = 0;
Q.nonphilosopher = 0;

Q.andrea_breakup = 0;
Q.selina_villain = 0;


Q.david_train = 0;
Q.talia_train = 0;
Q.shiva_train = 0;

Q.david_talk = 0;
Q.david_stop = 0;
Q.david_letgo = 0;
Q.david_confront = 0;

Q.dick_harvey_friends = 0;

Q.tim1 = 0;
Q.tim2 = 0;
Q.tim3 = 0;

Q.hamilton_support = 0;
Q.quincy_support = 0;

Q.seeingasbatman = 0;
Q.seeingasbruce = 1;

// Chart flags
Q.quincy_crime_rate = 0;

// This flag determines whether you see relations with corrupt councilmen or not.
Q.corrupt = 0;

// Knowledge flags
Q.damian_exists = 0;

// End of flags.




// media relation
Q.gotham_gazette_support = 0;
Q.daily_planet_support = 0;
Q.gotham_star_support = 0;
Q.media_empire_active = 0;

// events that have been seen
Q.election_1994_seen = 0

// Equipment

Q.stealth_suit = 0;

//business board corruption (0: controlled, 1: subdued, 2: clean, 3: corrupt)
Q.business_board_corruption = 3;
//batman's moral compass
Q.moral_compass = 50; // 0-100 scale (0 = i am vengence, 50 = i am the night, 100 = i am justice)

Q.political_perception = 50; // 0-100 scale (0 = Right Wing, 50 = Independent/Centrist, 100 = Left Wing)

// music

Q.horse_music = 0;


!}
on-display: {!
        window.disableHiddenBatmanMode();
        window.enableBatmanMode();

!}
set-bg: img/map_2.jpg
new-page: true

- @1994_debug: Debug Enter
- @1994_normal: Begin (normal difficulty)
- @1994_hard: Begin (hard difficulty)
- @1994_historical: Begin (historical mode)

@1994_debug
on-arrival:  {!
  Q.difficulty = -2
!}
go-to: election_1994

@1994_easy
on-arrival: {!
  Q.difficulty = -1;
!}
go-to: welcome

@1994_hard
on-arrival: {!
  Q.difficulty = 1;
!}
go-to: welcome

@1994_historical
on-arrival: {!
Q.difficulty = 2;
Q.historical_mode = 1;
this.state.disableSaves = true;
!}
go-to: welcome

@1994_normal
on-arrival: {!
  Q.difficulty = 0;
!}
go-to: welcome

@1994_main
new-page: true
go-to: main if difficulty >= 0 and election_1994; main.main_easy if difficulty < 0; election_1994 if election_1994_seen == 0

= [+ month:month +], [+ year +]